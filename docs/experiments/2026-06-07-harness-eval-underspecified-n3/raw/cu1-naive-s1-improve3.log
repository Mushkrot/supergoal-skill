{"type":"item.completed","item":{"id":"item_8","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,160p' docs/changelog/changelog-2026-06-07.md\"","aggregated_output":"## deepMerge implementation\n\n- Implemented `deepMerge(target, source)` as a recursive merge for plain objects.\n- Source values override target values when the value is not a plain object, keeping array and primitive behavior simple.\n- Tightened the behavior around nested values: merge only plain objects, replace arrays and class instances, copy nested source objects to avoid source aliasing, and ignore prototype-pollution keys.\n- Read enumerable property descriptors directly so source getters are not run during the merge and inherited target setters cannot intercept writes.\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,240p' test/merge.visible.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport { test } from 'node:test';\nimport { deepMerge } from '../src/merge.mjs';\n\ntest('merges two flat objects; source overrides target', () => {\n  assert.deepEqual(deepMerge({ a: 1, b: 2 }, { b: 3, c: 4 }), { a: 1, b: 3, c: 4 });\n});\n\ntest('deep merges nested plain objects', () => {\n  const target = { a: { keep: true, replace: 1 }, untouched: true };\n  const source = { a: { replace: 2, add: true } };\n\n  assert.equal(deepMerge(target, source), target);\n  assert.deepEqual(target, { a: { keep: true, replace: 2, add: true }, untouched: true });\n});\n\ntest('replaces arrays and other non-plain values', () => {\n  const date = new Date('2026-06-07T00:00:00.000Z');\n  const merged = deepMerge({ a: { nested: true }, list: [1], date: null }, { a: [2], list: [3], date });\n\n  assert.deepEqual(merged.a, [2]);\n  assert.deepEqual(merged.list, [3]);\n  assert.equal(merged.date, date);\n});\n\ntest('copies nested source objects when the target has no object to merge', () => {\n  const source = { a: { b: 1 } };\n  const merged = deepMerge({}, source);\n\n  assert.deepEqual(merged, source);\n  assert.notEqual(merged.a, source.a);\n});\n\ntest('merges enumerable symbol keys', () => {\n  const key = Symbol('key');\n\n  assert.equal(deepMerge({}, { [key]: { value: 1 } })[key].value, 1);\n});\n\ntest('ignores prototype pollution keys', () => {\n  const source = JSON.parse('{\"__proto__\":{\"polluted\":true},\"constructor\":{\"prototype\":{\"polluted\":true}}}');\n\n  assert.deepEqual(deepMerge({}, source), {});\n  assert.equal({}.polluted, undefined);\n});\n\ntest('does not invoke source getters while merging', () => {\n  let calls = 0;\n  const source = {};\n  Object.defineProperty(source, 'value', {\n    enumerable: true,\n    get() {\n      calls += 1;\n      return 1;\n    },\n  });\n\n  const merged = deepMerge({}, source);\n\n  assert.equal(calls, 0);\n  assert.equal(merged.value, 1);\n  assert.equal(calls, 1);\n});\n\ntest('defines properties without invoking inherited target setters', () => {\n  let setterCalls = 0;\n  Object.defineProperty(Object.prototype, 'value', {\n    configurable: true,\n    set value(_) {\n      setterCalls += 1;\n    },\n  });\n\n  try {\n    const target = {};\n    deepMerge(target, { value: 1 });\n\n    assert.equal(setterCalls, 0);\n    assert.equal(target.value, 1);\n  } finally {\n    delete Object.prototype.value;\n  }\n});\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' src/merge.mjs\"","aggregated_output":"export function deepMerge(target, source) {\n  if (!isPlainObject(target)) {\n    target = {};\n  }\n\n  if (!isPlainObject(source)) {\n    return target;\n  }\n\n  for (const key of enumerableOwnKeys(source)) {\n    if (isUnsafeKey(key)) {\n      continue;\n    }\n\n    const descriptor = Object.getOwnPropertyDescriptor(source, key);\n    if (!descriptor || !descriptor.enumerable) {\n      continue;\n    }\n\n    if (!('value' in descriptor)) {\n      Object.defineProperty(target, key, descriptor);\n      continue;\n    }\n\n    const value = descriptor.value;\n\n    if (isPlainObject(value)) {\n      const targetDescriptor = Object.getOwnPropertyDescriptor(target, key);\n      descriptor.value = deepMerge(isPlainObject(targetDescriptor?.value) ? targetDescriptor.value : {}, value);\n    } else {\n      descriptor.value = value;\n    }\n\n    Object.defineProperty(target, key, descriptor);\n  }\n\n  return target;\n}\n\nfunction enumerableOwnKeys(object) {\n  return Reflect.ownKeys(object).filter((key) => Object.prototype.propertyIsEnumerable.call(object, key));\n}\n\nfunction isPlainObject(value) {\n  if (value === null || typeof value !== 'object' || Array.isArray(value)) {\n    return false;\n  }\n\n  const prototype = Object.getPrototypeOf(value);\n  return prototype === Object.prototype || prototype === null;\n}\n\nfunction isUnsafeKey(key) {\n  return key === '__proto__' || key === 'constructor' || key === 'prototype';\n}\n","exit_code":0,"status":"completed"}}
