{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,240p' src/csv.mjs\"","aggregated_output":"export function parseCsvLine(line) {\n  const fields = [];\n  let field = '';\n  let inQuotes = false;\n  let quoteClosed = false;\n\n  for (let i = 0; i < line.length; i += 1) {\n    const char = line[i];\n\n    if (inQuotes) {\n      if (char === '\"') {\n        if (line[i + 1] === '\"') {\n          field += '\"';\n          i += 1;\n        } else {\n          inQuotes = false;\n          quoteClosed = true;\n        }\n      } else {\n        field += char;\n      }\n      continue;\n    }\n\n    if (char === '\\r' || char === '\\n') {\n      const terminatorLength = char === '\\r' && line[i + 1] === '\\n' ? 2 : 1;\n      if (i + terminatorLength === line.length) {\n        break;\n      }\n    }\n\n    if (char === ',') {\n      fields.push(field);\n      field = '';\n      quoteClosed = false;\n      continue;\n    }\n\n    if (char === '\"') {\n      if (field !== '' || quoteClosed) {\n        throw new Error('Invalid CSV quote');\n      }\n      inQuotes = true;\n      continue;\n    }\n\n    if (quoteClosed) {\n      throw new Error('Invalid CSV character after closing quote');\n    }\n\n    field += char;\n  }\n\n  if (inQuotes) {\n    throw new Error('Unclosed CSV quote');\n  }\n\n  fields.push(field);\n  return fields;\n}\n","exit_code":0,"status":"completed"}}
