{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,240p' test/merge.visible.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport { test } from 'node:test';\nimport { deepMerge } from '../src/merge.mjs';\n\ntest('merges two flat objects; source overrides target', () => {\n  assert.deepEqual(deepMerge({ a: 1, b: 2 }, { b: 3, c: 4 }), { a: 1, b: 3, c: 4 });\n});\n\ntest('deep merges nested plain objects', () => {\n  const target = { a: { keep: true, replace: 1 }, untouched: true };\n  const source = { a: { replace: 2, add: true } };\n\n  assert.equal(deepMerge(target, source), target);\n  assert.deepEqual(target, { a: { keep: true, replace: 2, add: true }, untouched: true });\n});\n\ntest('replaces arrays and other non-plain values', () => {\n  const date = new Date('2026-06-07T00:00:00.000Z');\n  const merged = deepMerge({ a: { nested: true }, list: [1], date: null }, { a: [2], list: [3], date });\n\n  assert.deepEqual(merged.a, [2]);\n  assert.deepEqual(merged.list, [3]);\n  assert.equal(merged.date, date);\n});\n\ntest('copies nested source objects when the target has no object to merge', () => {\n  const source = { a: { b: 1 } };\n  const merged = deepMerge({}, source);\n\n  assert.deepEqual(merged, source);\n  assert.notEqual(merged.a, source.a);\n});\n\ntest('merges enumerable symbol keys', () => {\n  const key = Symbol('key');\n\n  assert.equal(deepMerge({}, { [key]: { value: 1 } })[key].value, 1);\n});\n\ntest('ignores prototype pollution keys', () => {\n  const source = JSON.parse('{\"__proto__\":{\"polluted\":true},\"constructor\":{\"prototype\":{\"polluted\":true}}}');\n\n  assert.deepEqual(deepMerge({}, source), {});\n  assert.equal({}.polluted, undefined);\n});\n","exit_code":0,"status":"completed"}}
