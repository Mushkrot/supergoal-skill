{"type":"item.completed","item":{"id":"item_24","type":"command_execution","command":"/bin/zsh -lc 'nl -ba src/merge.mjs'","aggregated_output":"     1\texport function deepMerge(target, source) {\n     2\t  if (!isPlainObject(target) || !isPlainObject(source)) {\n     3\t    return target;\n     4\t  }\n     5\t\n     6\t  for (const [key, descriptor] of getEnumerableOwnDataEntries(source)) {\n     7\t    if (isUnsafeKey(key)) {\n     8\t      continue;\n     9\t    }\n    10\t\n    11\t    const sourceValue = descriptor.value;\n    12\t    const targetValue = target[key];\n    13\t\n    14\t    if (isPlainObject(targetValue) && isPlainObject(sourceValue)) {\n    15\t      deepMerge(targetValue, sourceValue);\n    16\t    } else {\n    17\t      target[key] = sourceValue;\n    18\t    }\n    19\t  }\n    20\t\n    21\t  return target;\n    22\t}\n    23\t\n    24\tfunction isObject(value) {\n    25\t  return value !== null && typeof value === 'object';\n    26\t}\n    27\t\n    28\tfunction isPlainObject(value) {\n    29\t  if (!isObject(value)) {\n    30\t    return false;\n    31\t  }\n    32\t\n    33\t  const prototype = Object.getPrototypeOf(value);\n    34\t  return prototype === Object.prototype || prototype === null;\n    35\t}\n    36\t\n    37\tfunction isUnsafeKey(key) {\n    38\t  return key === '__proto__' || key === 'constructor' || key === 'prototype';\n    39\t}\n    40\t\n    41\tfunction getEnumerableOwnDataEntries(value) {\n    42\t  return Reflect.ownKeys(value)\n    43\t    .map((key) => [key, Object.getOwnPropertyDescriptor(value, key)])\n    44\t    .filter(([, descriptor]) => descriptor.enumerable && 'value' in descriptor);\n    45\t}\n","exit_code":0,"status":"completed"}}
