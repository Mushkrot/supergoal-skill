{"type":"item.completed","item":{"id":"item_6","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,200p' docs/changelog/changelog-2026-06-07.md\"","aggregated_output":"# Changelog 2026-06-07\n\n## deepMerge\n\n- Implemented `deepMerge(target, source)` as an in-place merge that returns `target`, matching the task wording.\n- Recursively merges only plain object values; arrays, `null`, dates, and primitive values from `source` replace the target value.\n- Skips prototype-polluting keys to avoid unsafe side effects while merging untrusted object data.\n- Added regression coverage for nested merges, replacement values, non-object inputs, and unsafe keys because the visible flat-object test did not cover the full contract.\n- Tightened top-level inputs to plain objects and included enumerable symbol keys because deep object merge should not treat arrays or built-ins as merge containers, but should preserve all own enumerable object properties.\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_8","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' src/merge.mjs\"","aggregated_output":"export function deepMerge(target, source) {\n  if (!isPlainObject(target) || !isPlainObject(source)) {\n    return target;\n  }\n\n  for (const key of getEnumerableOwnKeys(source)) {\n    if (isUnsafeKey(key)) {\n      continue;\n    }\n\n    const sourceValue = source[key];\n    const targetValue = target[key];\n\n    if (isPlainObject(targetValue) && isPlainObject(sourceValue)) {\n      deepMerge(targetValue, sourceValue);\n    } else {\n      target[key] = sourceValue;\n    }\n  }\n\n  return target;\n}\n\nfunction isObject(value) {\n  return value !== null && typeof value === 'object';\n}\n\nfunction isPlainObject(value) {\n  if (!isObject(value)) {\n    return false;\n  }\n\n  const prototype = Object.getPrototypeOf(value);\n  return prototype === Object.prototype || prototype === null;\n}\n\nfunction isUnsafeKey(key) {\n  return key === '__proto__' || key === 'constructor' || key === 'prototype';\n}\n\nfunction getEnumerableOwnKeys(value) {\n  return Reflect.ownKeys(value).filter((key) => {\n    return Object.prototype.propertyIsEnumerable.call(value, key);\n  });\n}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,240p' test/merge.visible.test.mjs\"","aggregated_output":"import assert from 'node:assert/strict';\nimport { test } from 'node:test';\nimport { deepMerge } from '../src/merge.mjs';\n\ntest('merges two flat objects; source overrides target', () => {\n  assert.deepEqual(deepMerge({ a: 1, b: 2 }, { b: 3, c: 4 }), { a: 1, b: 3, c: 4 });\n});\n\ntest('deeply merges nested plain objects in place', () => {\n  const target = { a: { b: 1, c: 2 }, d: 3 };\n  const result = deepMerge(target, { a: { c: 4, e: 5 } });\n\n  assert.equal(result, target);\n  assert.deepEqual(result, { a: { b: 1, c: 4, e: 5 }, d: 3 });\n});\n\ntest('replaces arrays, null, dates, and primitives instead of merging them', () => {\n  const date = new Date('2026-06-07T00:00:00.000Z');\n  const result = deepMerge(\n    { items: [1], value: { nested: true }, date: new Date('2020-01-01T00:00:00.000Z') },\n    { items: [2, 3], value: null, date },\n  );\n\n  assert.deepEqual(result.items, [2, 3]);\n  assert.equal(result.value, null);\n  assert.equal(result.date, date);\n});\n\ntest('returns target unchanged when either input is not an object', () => {\n  const target = { a: 1 };\n\n  assert.equal(deepMerge(target, null), target);\n  assert.equal(deepMerge(null, { a: 2 }), null);\n  assert.deepEqual(target, { a: 1 });\n});\n\ntest('skips keys that can mutate prototypes', () => {\n  const payload = JSON.parse('{\"__proto__\":{\"polluted\":true},\"constructor\":{\"polluted\":true},\"safe\":1}');\n  const result = deepMerge({}, payload);\n\n  assert.deepEqual(result, { safe: 1 });\n  assert.equal({}.polluted, undefined);\n});\n\ntest('merges enumerable symbol keys', () => {\n  const token = Symbol('token');\n  const target = { [token]: { keep: true } };\n\n  const result = deepMerge(target, { [token]: { add: true } });\n\n  assert.equal(result, target);\n  assert.deepEqual(result[token], { keep: true, add: true });\n});\n\ntest('ignores non-plain top-level merge inputs', () => {\n  const arrayTarget = [1];\n  const dateTarget = new Date('2026-06-07T00:00:00.000Z');\n\n  assert.equal(deepMerge(arrayTarget, { 0: 2, extra: true }), arrayTarget);\n  assert.deepEqual(arrayTarget, [1]);\n  assert.equal(deepMerge(dateTarget, { extra: true }), dateTarget);\n  assert.equal(dateTarget.extra, undefined);\n});\n","exit_code":0,"status":"completed"}}
