{"type":"item.completed","item":{"id":"item_28","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,240p' src/semver.mjs\"","aggregated_output":"export function compareVersions(a, b) {\n  const first = parseVersion(a);\n  const second = parseVersion(b);\n\n  for (let i = 0; i < 3; i += 1) {\n    if (first.core[i] !== second.core[i]) {\n      return first.core[i] < second.core[i] ? -1 : 1;\n    }\n  }\n\n  return comparePrerelease(first.pre, second.pre);\n}\n\nfunction parseVersion(version) {\n  if (typeof version !== \"string\") {\n    throw new TypeError(\"version must be a semver string\");\n  }\n\n  const [coreAndPre] = version.split(\"+\", 2);\n  const [mainPart, prePart = \"\"] = coreAndPre.split(\"-\", 2);\n  const [major, minor, patch] = mainPart.split(\".\").map((part) => Number(part));\n\n  if (!Number.isInteger(major) || !Number.isInteger(minor) || !Number.isInteger(patch)) {\n    throw new TypeError(\"invalid semver core\");\n  }\n\n  const prerelease = prePart ? prePart.split(\".\") : [];\n\n  return {\n    core: [major, minor, patch],\n    pre: prerelease,\n  };\n}\n\nfunction comparePrerelease(a, b) {\n  if (!a.length && !b.length) return 0;\n  if (!a.length) return 1;\n  if (!b.length) return -1;\n\n  const len = Math.min(a.length, b.length);\n\n  for (let i = 0; i < len; i += 1) {\n    const [aIsNum, bIsNum] = [isNumId(a[i]), isNumId(b[i])];\n\n    if (aIsNum && bIsNum) {\n      const numA = Number(a[i]);\n      const numB = Number(b[i]);\n      if (numA !== numB) return numA < numB ? -1 : 1;\n    } else if (aIsNum && !bIsNum) {\n      return -1;\n    } else if (!aIsNum && bIsNum) {\n      return 1;\n    } else if (a[i] !== b[i]) {\n      return a[i] < b[i] ? -1 : 1;\n    }\n  }\n\n  return a.length === b.length ? 0 : a.length < b.length ? -1 : 1;\n}\n\nfunction isNumId(part) {\n  return /^0$|^[1-9]\\d*$/.test(part);\n}\n\nexport default compareVersions;\n","exit_code":0,"status":"completed"}}
