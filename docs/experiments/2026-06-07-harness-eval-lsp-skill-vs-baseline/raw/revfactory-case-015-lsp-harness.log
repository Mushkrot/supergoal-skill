}\n\n  push(chunk) {\n    this.buffer += typeof chunk === 'string' ? chunk : String(chunk ?? '');\n    const messages = [];\n\n    while (this.buffer.length > 0) {\n      const headerEnd = this.buffer.indexOf(CONTENT_END);\n      if (headerEnd === -1) break;\n\n      const header = this.buffer.slice(0, headerEnd);\n      const lengthMatch = /(\\\\d+)/.exec(header);\n      if (\"'!lengthMatch) {\n        const nextHeader = this.buffer.indexOf('\"'Content-Length', 1);\n        if (nextHeader === -1) break;\n        this.buffer = this.buffer.slice(nextHeader);\n        continue;\n      }\n\n      const length = Number.parseInt(lengthMatch[0], 10);\n      if (Number.isNaN(length) || length < 0 || length > MAX_BYTE_LENGTH) {\n        this.buffer = this.buffer.slice(headerEnd + CONTENT_END.length);\n        continue;\n      }\n\n      const bodyStart = headerEnd + CONTENT_END.length;\n      const bodyEnd = bodyStart + length;\n      if (this.buffer.length < bodyEnd) break;\n\n      const body = this.buffer.slice(bodyStart, bodyEnd);\n      this.buffer = this.buffer.slice(bodyEnd);\n      try {\n        messages.push(JSON.parse(body));\n      } catch {\n        continue;\n      }\n    }\n\n    return messages;\n  }\n}\n\nexport function parseMiniLang(text) {\n  const source = typeof text === 'string' ? text : String(text ?? '');\n  const lines = source.split(/\\\\r?\\\\n/);\n  const diagnostics = [];\n  const functions = [];\n  const variables = [];\n  const calls = [];\n  const functionByName = Object.create(null);\n  const variableByName = Object.create(null);\n\n  for (let lineNo = 0; lineNo < lines.length; lineNo += 1) {\n    const line = stripComment(lines[lineNo]);\n    const trimmed = line.trim();\n    if (\"'!trimmed) continue;\n\n    if (/''^'\"\\\\s*fn\\\\b/.test(trimmed)) {\n      const nameMatch = /\"'^'\"\\\\s*fn\\\\s+([A-Za-z_][A-Za-z0-9_]*)/.exec(line);\n      if (\"'!nameMatch) {\n        addDiagnostic(diagnostics, '\"'Invalid function declaration', lineNo,