 [];\n\n    while (true) {\n      const headerEnd = this.buffer.indexOf('\\r\\n\\r\\n');\n      if (headerEnd === -1) break;\n\n      const header = this.buffer.subarray(0, headerEnd).toString('ascii');\n      const match = /(?:^|\\r\\n)Content-Length:\\s*(\\d+)\\s*(?:\\r\\n|$)/i.exec(header);\n      if (!match) {\n        this.buffer = this.buffer.subarray(headerEnd + 4);\n        continue;\n      }\n\n      const length = Number(match[1]);\n      const bodyStart = headerEnd + 4;\n      const bodyEnd = bodyStart + length;\n      if (this.buffer.length < bodyEnd) break;\n\n      const body = this.buffer.subarray(bodyStart, bodyEnd).toString('utf8');\n      this.buffer = this.buffer.subarray(bodyEnd);\n      messages.push(JSON.parse(body));\n    }\n\n    return messages;\n  }\n}\n\nfunction position(line, character) {\n  return { line, character };\n}\n\nfunction range(startLine, startChar, endLine = startLine, endChar = startChar) {\n  return { start: position(startLine, startChar), end: position(endLine, endChar) };\n}\n\nfunction severityError() {\n  return 1;\n}\n\nfunction diagnostic(message, startLine, startChar, endLine = startLine, endChar = startChar + 1) {\n  return { severity: severityError(), message, range: range(startLine, startChar, endLine, endChar) };\n}\n\nfunction stripComment(line) {\n  const index = line.indexOf('#');\n  return index === -1 ? line : line.slice(0, index);\n}\n\nfunction wordAt(text, pos) {\n  const lines = text.split('\\n');\n  const line = lines[pos.line] ?? '';\n  let start = Math.min(pos.character, line.length);\n  while (start > 0 && /[A-Za-z0-9_]/.test(line[start - 1])) start -= 1;\n  let end = Math.min(pos.character, line.length);\n  while (end < line.length && /[A-Za-z0-9_]/.test(line[end])) end += 1;\n  const word = line.slice(start, end);\n  return IDENT_RE.test(word) ? { word, range: range(pos.line, start, pos.line, end) } : null;\n}\n\nfunction splitArgs(args) {\n  const trimmed = args.trim();\n  if (!trimmed) return [];\n  return trimmed.split(',').map((item) => item.trim()).filter(Boolean);\n}\n\nfunction scanIdentifiers(expr) {\n  const found = [];\n  for (const match of expr.matchAll(/[A-Za-z_][A-Za-z0-9_]*/g)) {\n    found.push({ name: match[0], start: match.index });\n  }\n  return found;\n}\n\nfunction scanCalls(expr) {\n  const found = [];\n  for (const match of expr.matchAll(/\\b([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^()]*)\\)/g)) {\n    found.push({ name: match[1], args: splitArgs(match[2]), start: match.index });\n  }\n  return found;\n}\n\nfunction symbol(name, kind, line, start, end, extra = {}) {\n  return { name, kind, range: range(line, start, line, end), selectionRange: range(line, start, line, end), ...extra };\n}\n\nexport function parseMiniLang(text) {\n  const diagnostics = [];\n  const symbols = [];\n  const functions = new Map();\n  const lines = text.split('\\n');\n  let current = null;\n  let braceDepth = 0;\n\n  for (let lineNo = 0; lineNo < lines.length; lineNo += 1) {\n    const raw = lines[lineNo];\n    const line = stripComment(raw);\n    const trimmed = line.trim();\n    const indent = line.search(/\\S|$/);\n    if (!trimmed) continue;\n\n    const fnMatch = /^fn\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\(([^)]*)\\)\\s*\\{?/.exec(trimmed);\n    if (fnMatch) {\n      const name = fnMatch[1];\n      const nameStart = line.indexOf(name, indent);\n      const params = splitArgs(fnMatch[2]);\n      const invalidParam = params.find((param) => !IDENT_RE.test(param));\n      if (invalidParam) diagnostics.push(diagnostic(`Invalid parameter '${invalidParam}'`, lineNo, line.indexOf(invalidParam)));\n      if (!trimmed.includes('{')) diagnostics.push(diagnostic(`Expected '{' after function declaration`, lineNo, line.length));\n      if (functions.has(name)) diagnostics.push(diagnostic(`Duplicate function '${name}'`, lineNo, nameStart, lineNo, nameStart + name.length));\n\n      const fnSymbol = symbol(name, 'function', lineNo, nameStart, nameStart + name.length, {\n        params,\n        signature: `fn ${name}(${params.join(', ')})`,\n        locals: new Map(),\n      });\n      symbols.push(fnSymbol);\n      functions.set(name, fnSymbol);\n      current = fnSymbol;\n      braceDepth = (line.match(/\\{/g) ?? []).length - (line.match(/\\}/g) ?? []).length;\n      for (const param of params) {\n        const start = line.indexOf(param, line.indexOf('('));\n        current.locals.set(param, symbol(param, 'parameter', lineNo, start, start + param.length, { function: name }));\n      }\n      if (braceDepth <= 0) current = null;\n      continue;\n    }\n\n    if (!current) {\n      diagnostics.push(diagnostic(`Expected function declaration`, lineNo, indent, lineNo, Math.max(indent + 1, line.length)));\n      continue;\n    }\n\n    if (/^}/.test(trimmed)) {\n      braceDepth -= 1;\n      if (braceDepth <= 0) current = null;\n      continue;\n    }\n\n    const letMatch = /^let\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/.exec(trimmed);\n    const returnMatch = /^return(?:\\s+(.*))?$/.exec(trimmed);\n    let expression = null;\n    let expressionStart = -1;\n\n    if (letMatch) {\n      const name = letMatch[1];\n      const nameStart = line.indexOf(name, indent);\n      const local = symbol(name, 'variable', lineNo, nameStart, nameStart + name.length, { function: current.name });\n      current.locals.set(name, local);\n      symbols.push(local);\n      expression = letMatch[2] ?? '';\n      expressionStart = line.indexOf(expression, nameStart + name.length);\n    } else if (returnMatch) {\n      expression = returnMatch[1] ?? '';\n      expressionStart = expression ? line.indexOf(expression, indent) : -1;\n    } else {\n      diagnostics.push(diagnostic(`Unrecognized statement`, lineNo, indent, lineNo, Math.max(indent + 1, line.length)));\n      expression = trimmed;\n      expressionStart = indent;\n    }\n\n    if (expression != null && expressionStart >= 0) {\n      const calls = scanCalls(expression);\n      const calledStarts = new Set(